FASTER-WHISPER BACKEND (CTranslate2) — Translation, 99+ languages, prompting
═════════════════════════════════════════════════════════════════════════════

    distil-large-v3.5  [DEFAULT]     ~2GB VRAM
      Aliases: distil-v3.5
      99+ languages, English-optimized, fastest Whisper model

    large-v3-turbo                   ~3GB VRAM
      Aliases: turbo
      99+ languages, good speed/accuracy balance

    large-v3                         ~5GB VRAM
      99+ languages, highest Whisper accuracy

    distil-large-v3                  ~2GB VRAM
      Previous distil generation

    medium / small / tiny / base     Various sizes
      Lower accuracy, less VRAM, faster

EXPLICIT MODEL SELECTION:
    --backend parakeet -m v3              Use Parakeet v3
    --backend faster-whisper -m turbo     Use Whisper large-v3-turbo
    -m nvidia/parakeet-tdt-0.6b-v3       Full HuggingFace path (any model)
    -m canary-v2 --translate              Canary translation
EOF
    exit 0
}

show_routing() {
    cat <<'EOF'
Auto-routing logic:

1. If --backend is specified → use that backend (error if unavailable)
2. If any faster-whisper-only flag is detected → use faster-whisper
3. Otherwise → prefer Parakeet (if available), fall back to faster-whisper

SHARED features (work on BOTH backends):
    --diarize, --min-speakers, --max-speakers, --speaker-names, --export-speakers
    --search, --search-fuzzy
    --detect-chapters, --chapter-gap, --chapters-file, --chapter-format
    --format text|json|srt|vtt|ass|lrc|ttml|csv|tsv|html
    --clean-filler, --filter-hallucinations
    --normalize, --denoise
    --burn-in
    --merge-sentences, --detect-paragraphs, --paragraph-gap
    --rss, --rss-latest
    --channel
    --stats-file

Flags that force faster-whisper (Whisper-model-specific):
    --translate, --multilingual
    --initial-prompt, --hotwords, --prefix
    --language-map
    --parallel
    --stream (fw streaming with segment output)
    --no-condition-on-previous-text, --condition-on-previous-text
    --clip-timestamps
    --temperature (explicit)
    --compression-ratio-threshold, --log-prob-threshold
    --min-confidence
    --no-vad, --vad-threshold, --vad-neg-threshold, --vad-onset, --vad-offset
    --min-speech-duration, --max-speech-duration, --min-silence-duration, --speech-pad
    --no-batch
    --no-timestamps
    --no-suppress-blank, --suppress-tokens
    --max-initial-timestamp
    --prepend-punctuations, --append-punctuations
    --best-of, --patience, --repetition-penalty, --no-repeat-ngram-size
    --prompt-reset-on-temperature
    --chunk-length (fw meaning)
    --max-new-tokens
    --hallucination-silence-threshold
    --log-level
    --retries, --keep-temp
    --hf-token, --revision
    --compute-type, --threads, --model-dir
    --output-template
    --word-timestamps (fw-specific; parakeet uses --timestamps)
    --progress

Flags that force Parakeet:
    --long-form
    --streaming (parakeet chunked inference)
    --fast (small 110M model)
    --multitalker (multi-speaker pipeline)
    --source-lang, --target-lang (Canary translation)

Language routing:
    Non-European languages (e.g. -l ja, -l zh, -l ar) → faster-whisper
    European languages or auto-detect → either backend
EOF
    exit 0
}

# ── Faster-whisper-only flags ─────────────────────────────────────────
# These flags are specific to the Whisper model or faster-whisper's inference engine.
# Shared features (diarization, search, chapters, filler, formats, preprocessing,
# burn-in, RSS, speakers) are NOT listed here — they work on both backends.

# No-value flags that force faster-whisper
FW_ONLY_NOVAL=(
    --translate --multilingual
    --no-condition-on-previous-text --condition-on-previous-text
    --no-vad --no-batch --no-timestamps --no-suppress-blank
    --progress --keep-temp
    --word-timestamps
    --detect-language-only
)

# Value flags that force faster-whisper
FW_ONLY_WITHVAL=(
    --initial-prompt --hotwords --prefix
    --language-map --parallel
    --hallucination-silence-threshold
    --clip-timestamps --temperature
    --compression-ratio-threshold --log-prob-threshold --min-confidence
    --vad-threshold --vad-neg-threshold --vad-onset --vad-offset
    --min-speech-duration --max-speech-duration --min-silence-duration --speech-pad
    --suppress-tokens --max-initial-timestamp
    --prepend-punctuations --append-punctuations
    --best-of --patience --repetition-penalty --no-repeat-ngram-size
    --prompt-reset-on-temperature --chunk-length --max-new-tokens
    --log-level --retries --hf-token --revision
    --compute-type --threads --model-dir
    --output-template
    --no-speech-threshold
    --language-detection-threshold --language-detection-segments
    --length-penalty
)

# Parakeet-only flags
PK_ONLY_NOVAL=(--long-form --streaming --no-align)
PK_ONLY_WITHVAL=(--source-lang --target-lang)

# Non-European languages that require faster-whisper (Parakeet only supports 25 EU langs)
PARAKEET_LANGS="bg hr cs da nl en et fi fr de el hu it lv lt mt pl pt ro sk sl es sv ru uk"

# ── Parse args ────────────────────────────────────────────────────────

is_in_array() {
    local needle="$1"; shift
    for item in "$@"; do
        [ "$item" = "$needle" ] && return 0
    done
    return 1
}

FORCED_BACKEND=""
PASSTHROUGH=()
needs_fw=false
needs_pk=false
AGENT_MODE=false
PROBE_MODE=false

while [ $# -gt 0 ]; do
    arg="$1"
    case "$arg" in
        --help|-h)       usage ;;
        --check)
            if [ "${2:-}" = "--json" ]; then
                check_health --json
            else
                check_health
            fi
            ;;
        --quickstart)
            # Collect sub-flags: --json, --all (in any order after --quickstart)
            _qs_args=()
            shift
            while [ $# -gt 0 ]; do
                case "$1" in
                    --json|--all|--dry-run) _qs_args+=("$1"); shift ;;
                    *) break ;;
                esac
            done
            quickstart "${_qs_args[@]}"
            ;;
        --backends)      show_backends ;;
        --help-models)   show_models ;;
        --help-routing)  show_routing ;;

        # ── Probe mode (quick metadata, no transcription) ──
        --probe)
            PROBE_MODE=true
            shift; continue
            ;;

        # ── Version ──
        --version)
            echo "super-transcribe $SUPER_TRANSCRIBE_VERSION"
            if backend_ready "faster-whisper"; then
                fw_ver=$("$FW_DIR/.venv/bin/python" -c "import importlib.metadata; print(importlib.metadata.version('faster-whisper'))" 2>/dev/null || echo "unknown")
                echo "  faster-whisper: $fw_ver"
            fi
            if backend_ready "parakeet"; then
                pk_ver=$("$PK_DIR/venv/bin/python" -c "import importlib.metadata; print(importlib.metadata.version('nemo_toolkit'))" 2>/dev/null || echo "unknown")
                echo "  nemo_toolkit: $pk_ver"
            fi
            exit 0
            ;;

        # ── Setup command ──
        --setup)
            [ $# -ge 2 ] || die "--setup requires a value: faster-whisper | parakeet | all"
            _setup_target="$2"; shift 2
            # Check remaining args for --diarize
            for _sa in "$@"; do
                [ "$_sa" = "--diarize" ] && SETUP_DIARIZE=true
            done
            setup_backend "$_setup_target"; exit 0
            ;;
        --setup=*)
            _setup_target="${arg#--setup=}"; shift
            for _sa in "$@"; do
                [ "$_sa" = "--diarize" ] && SETUP_DIARIZE=true
            done
            setup_backend "$_setup_target"; exit 0
            ;;

        # ── Fast mode (forces parakeet + 110M model) ──
        --fast)
            needs_pk=true
            PASSTHROUGH+=("$arg")
            shift; continue
            ;;

        # ── Multitalker mode (forces parakeet) ──
        --multitalker)
            needs_pk=true
            PASSTHROUGH+=("$arg")
            shift; continue
            ;;
        --multitalker-diar-model|--multitalker-asr-model)
            needs_pk=true
            PASSTHROUGH+=("$arg")
            if [ $# -ge 2 ] && [[ ! "$2" == -* ]]; then
                PASSTHROUGH+=("$2"); shift
            fi
            shift; continue
            ;;
        --multitalker-diar-model=*|--multitalker-asr-model=*)
            needs_pk=true
            PASSTHROUGH+=("$arg")
            shift; continue
            ;;

        # ── Resume (pass through to backend) ──
        --resume)
            [ $# -ge 2 ] || die "--resume requires a checkpoint file path"
            PASSTHROUGH+=("$arg" "$2"); shift 2; continue
            ;;
        --resume=*)
            PASSTHROUGH+=("$arg"); shift; continue
            ;;

        # ── Agent mode (compact JSON output, suppress stderr) ──
        --agent)
            AGENT_MODE=true
            PASSTHROUGH+=("$arg")
            shift; continue
            ;;

        # ── Backend selection (consume, don't pass through) ──
        --backend)
            [ $# -ge 2 ] || die "--backend requires a value: faster-whisper | parakeet"
            FORCED_BACKEND="$2"; shift 2; continue
            ;;
        --backend=*)
            FORCED_BACKEND="${arg#--backend=}"; shift; continue
            ;;

        # ── Language check (non-EU languages force faster-whisper) ──
        -l|--language)
            PASSTHROUGH+=("$arg")
            if [ $# -ge 2 ]; then
                lang="$2"
                # Check if this language is NOT in Parakeet's supported list
                lang_supported=false
                for pl in $PARAKEET_LANGS; do
                    if [ "$lang" = "$pl" ]; then
                        lang_supported=true
                        break
                    fi
                done
                if ! $lang_supported; then
                    needs_fw=true
                fi
            fi
            ;;
        --language=*)
            PASSTHROUGH+=("$arg")
            lang="${arg#--language=}"
            lang_supported=false
            for pl in $PARAKEET_LANGS; do
                if [ "$lang" = "$pl" ]; then
                    lang_supported=true
                    break
                fi
            done
            if ! $lang_supported; then
                needs_fw=true
            fi
            ;;

        # ── Flag classification ──
        *)
            if is_in_array "$arg" "${FW_ONLY_NOVAL[@]}"; then
                needs_fw=true
                PASSTHROUGH+=("$arg")
            elif is_in_array "$arg" "${FW_ONLY_WITHVAL[@]}"; then
                needs_fw=true
                PASSTHROUGH+=("$arg")
                # Pass through the value arg if present (not --flag=value form)
                if [ $# -ge 2 ] && [[ ! "$2" == -* ]]; then
                    PASSTHROUGH+=("$2"); shift
                fi
            elif is_in_array "$arg" "${PK_ONLY_NOVAL[@]}"; then
                needs_pk=true
                PASSTHROUGH+=("$arg")
            elif is_in_array "$arg" "${PK_ONLY_WITHVAL[@]}"; then
                needs_pk=true
                PASSTHROUGH+=("$arg")
                if [ $# -ge 2 ] && [[ ! "$2" == -* ]]; then
                    PASSTHROUGH+=("$2"); shift
                fi
            else
                # Check --flag=value form for fw-only or pk-only flags
                flag_part="${arg%%=*}"
                if [ "$flag_part" != "$arg" ]; then
                    if is_in_array "$flag_part" "${FW_ONLY_WITHVAL[@]}"; then
                        needs_fw=true
                    elif is_in_array "$flag_part" "${PK_ONLY_WITHVAL[@]}"; then
                        needs_pk=true
                    fi
                fi
                PASSTHROUGH+=("$arg")
            fi
            ;;
    esac
    shift
done

# ── Resolve backend ───────────────────────────────────────────────────

normalize_backend() {
    case "$1" in
        faster-whisper|fw|whisper) echo "faster-whisper" ;;
        parakeet|pk|nemo)          echo "parakeet" ;;
        *)                         echo "" ;;
    esac
}

# ── Probe mode: run and exit before backend selection ─────────────
if $PROBE_MODE; then
    # Find audio files in passthrough args (non-flag args)
    PROBE_FILES=()
    for p_arg in "${PASSTHROUGH[@]}"; do
        if [[ ! "$p_arg" == -* ]] && [ -f "$p_arg" ]; then
            PROBE_FILES+=("$p_arg")
        fi
    done
    if [ ${#PROBE_FILES[@]} -eq 0 ]; then
        die "No audio file specified for --probe" 3
    fi
    # Use Python with shared lib to probe
    PROBE_SCRIPT="
import sys, json
sys.path.insert(0, '$SCRIPT_DIR/backends')
from lib.audio import probe_audio
for f in sys.argv[1:]:
    print(json.dumps(probe_audio(f), ensure_ascii=False))
"
    python3 -c "$PROBE_SCRIPT" "${PROBE_FILES[@]}"
    exit 0
fi

# ── Resolve backend ───────────────────────────────────────────────────

if [ -n "$FORCED_BACKEND" ]; then
    BACKEND=$(normalize_backend "$FORCED_BACKEND")
    [ -n "$BACKEND" ] || die "Unknown backend '$FORCED_BACKEND'. Choose: faster-whisper | parakeet" 3
    backend_available "$BACKEND" || die "Backend '$BACKEND' files are missing from $SCRIPT_DIR/backends/" 2
elif $needs_fw && $needs_pk; then
    die "Conflicting flags: some require faster-whisper, others require parakeet. Use --backend to pick one." 3
elif $needs_fw; then
    backend_available "faster-whisper" || die "faster-whisper backend files are missing" 2
    BACKEND="faster-whisper"
elif $needs_pk; then
    backend_available "parakeet" || die "parakeet backend files are missing" 2
    BACKEND="parakeet"
else
    # Default: prefer parakeet (best accuracy + speed), fall back to faster-whisper
    if backend_available "parakeet"; then
        BACKEND="parakeet"
    elif backend_available "faster-whisper"; then
        BACKEND="faster-whisper"
    else
        die "No transcription backends found in $SCRIPT_DIR/backends/" 2
    fi
fi

# ── First-run UX: notify about backend setup ─────────────────────────
if ! backend_ready "$BACKEND"; then
    if $AGENT_MODE; then
        # In agent mode, emit a structured status to stderr before setup
        echo '{"status":"setting_up","backend":"'"$BACKEND"'","message":"Setting up '"$BACKEND"' backend for the first time. This may take 1-3 minutes (downloading models and dependencies)..."}' >&2
    else
        info "First-time setup for $BACKEND — installing dependencies and models. This may take 1-3 minutes..."
    fi
fi

if ! $AGENT_MODE; then
    info "Routing to $BACKEND"
fi
run_backend "$BACKEND" "${PASSTHROUGH[@]}"
